# ==============================================================================
# NEF Cadência - Environment Variables Template
# ==============================================================================
# 
# INSTRUCTIONS:
# 1. Copy this file to .env: cp .env.example .env
# 2. Fill in your actual values (NEVER use example values in production)
# 3. NEVER commit .env to version control
# 4. Keep .env file permissions restricted: chmod 600 .env
# 
# SECURITY LEVELS:
# 🔴 CRITICAL - Required in production, must be secure
# 🟠 REQUIRED - Required in production
# 🟡 OPTIONAL - Optional but recommended
# 🟢 DEV-ONLY - Only for development
# ==============================================================================

# ==============================================================================
# ENVIRONMENT SELECTION
# ==============================================================================
# 🟡 OPTIONAL - Auto-detected if not set
# Options: development, production, test
# Default: development
DJANGO_ENV=development

# ==============================================================================
# DJANGO CORE SETTINGS
# ==============================================================================

# ------------------------------------------------------------------------------
# 🔴 CRITICAL: Secret Key
# ------------------------------------------------------------------------------
# PRODUCTION: MUST be a secure random string of 50+ characters
# DEVELOPMENT: Can use any value for local testing
# 
# Generate secure key:
#   python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
#
# NEVER use default values like:
#   - "change-me-in-production"
#   - "django-insecure-..."
#   - "your-secret-key-here"
#   - "secret" or "secretkey"
SECRET_KEY=your-secret-key-here-CHANGE-THIS-IN-PRODUCTION

# ------------------------------------------------------------------------------
# 🟢 DEV-ONLY: Debug Mode
# ------------------------------------------------------------------------------
# PRODUCTION: MUST be False (enforced by settings)
# DEVELOPMENT: Can be True for debugging
DEBUG=True

# ------------------------------------------------------------------------------
# 🔴 CRITICAL: Allowed Hosts
# ------------------------------------------------------------------------------
# PRODUCTION: MUST list your actual domain names (comma-separated)
# DEVELOPMENT: Can use localhost,127.0.0.1
# 
# Examples:
#   ALLOWED_HOSTS=example.com,www.example.com,api.example.com
#   ALLOWED_HOSTS=192.168.1.100,myapp.local
# 
# NEVER use in production:
#   - localhost
#   - 127.0.0.1
#   - 0.0.0.0
ALLOWED_HOSTS=127.0.0.1,localhost

# ==============================================================================
# DATABASE CONFIGURATION (PostgreSQL)
# ==============================================================================

# ------------------------------------------------------------------------------
# 🔴 CRITICAL: Database Credentials
# ------------------------------------------------------------------------------
# PRODUCTION: Use strong passwords (16+ characters, mixed case, numbers, symbols)
# DEVELOPMENT: Can use simple values for local database

# Database name
DB_NAME=alive_platform

# Database user
DB_USER=postgres

# Database password
# PRODUCTION: Generate with: openssl rand -base64 32
DB_PASSWORD=your-secure-database-password-here

# Database host
# PRODUCTION: Use internal hostname or IP
# DEVELOPMENT: localhost or 127.0.0.1
DB_HOST=127.0.0.1

# Database port (default: 5432 for PostgreSQL)
DB_PORT=5432

# Connection pooling (seconds)
# PRODUCTION: 600 (10 minutes) recommended
# DEVELOPMENT: 0 (no pooling) for easier debugging
DB_CONN_MAX_AGE=0

# ==============================================================================
# LEGACY DATABASE (SQL Server) - OPTIONAL
# ==============================================================================
# 🟡 OPTIONAL - Only if syncing with legacy LH_ALIVE system
# Leave empty if not using legacy sync

# Legacy database driver (e.g., "ODBC Driver 17 for SQL Server")
LEGACY_DRIVER=

# Legacy database server hostname or IP
LEGACY_SERVER=

# Legacy database port (default: 1433 for SQL Server)
LEGACY_PORT=

# Legacy database username
LEGACY_USER=

# Legacy database password
LEGACY_PASSWORD=

# Legacy database name
LEGACY_DATABASE=

# Legacy database schema (default: dbo)
LEGACY_SCHEMA=dbo

# Legacy events table name (default: agent_events)
LEGACY_EVENTS_TABLE=agent_events

# ==============================================================================
# CACHE CONFIGURATION (Redis)
# ==============================================================================

# ------------------------------------------------------------------------------
# 🟠 REQUIRED (Production): Redis URL
# ------------------------------------------------------------------------------
# PRODUCTION: Required for session storage and caching
# DEVELOPMENT: Optional (uses local memory cache if not set)
# 
# Format: redis://[username:password@]host:port/database
# Examples:
#   redis://localhost:6379/1
#   redis://:password@redis.example.com:6379/0
#   rediss://redis.example.com:6380/1  (SSL)
REDIS_URL=redis://127.0.0.1:6379/1

# ==============================================================================
# EMAIL CONFIGURATION (SMTP)
# ==============================================================================

# ------------------------------------------------------------------------------
# 🟠 REQUIRED (Production): Email Settings
# ------------------------------------------------------------------------------
# PRODUCTION: Required for password resets, notifications, error emails
# DEVELOPMENT: Optional (uses console backend if not set)

# SMTP server hostname
# Examples: smtp.gmail.com, smtp.sendgrid.net, smtp.mailgun.org
EMAIL_HOST=smtp.gmail.com

# SMTP server port
# Common ports: 587 (TLS), 465 (SSL), 25 (plain)
EMAIL_PORT=587

# Use TLS encryption
EMAIL_USE_TLS=True

# SMTP username (usually your email address)
EMAIL_HOST_USER=your-email@example.com

# SMTP password or app-specific password
# Gmail: Use App Password (https://support.google.com/accounts/answer/185833)
EMAIL_HOST_PASSWORD=your-email-app-password-here

# Default "From" email address
DEFAULT_FROM_EMAIL=noreply@example.com

# Server error notification email
SERVER_EMAIL=server@example.com

# ==============================================================================
# SECURITY SETTINGS (Production)
# ==============================================================================

# ------------------------------------------------------------------------------
# 🟠 REQUIRED (Production): CSRF Trusted Origins
# ------------------------------------------------------------------------------
# PRODUCTION: List all domains that will make AJAX requests (comma-separated)
# DEVELOPMENT: Not required
# 
# MUST include protocol (https://)
# Examples:
#   CSRF_TRUSTED_ORIGINS=https://example.com,https://www.example.com
#   CSRF_TRUSTED_ORIGINS=https://api.example.com,https://admin.example.com
CSRF_TRUSTED_ORIGINS=

# ------------------------------------------------------------------------------
# 🟡 OPTIONAL: HSTS Settings
# ------------------------------------------------------------------------------
# PRODUCTION: Recommended for enhanced security
# DEVELOPMENT: Not used

# HSTS max age in seconds (default: 31536000 = 1 year)
SECURE_HSTS_SECONDS=31536000

# Force HTTPS redirect (default: True in production)
SECURE_SSL_REDIRECT=True

# ==============================================================================
# OPENAI CONFIGURATION
# ==============================================================================

# ------------------------------------------------------------------------------
# 🟠 REQUIRED: OpenAI API Key
# ------------------------------------------------------------------------------
# Required for AI assistant features
# 
# Get your API key: https://platform.openai.com/api-keys
# Format: sk-...
# 
# PRODUCTION: Use production API key with usage limits
# DEVELOPMENT: Can use development/test API key
OPENAI_API_KEY=sk-your-openai-api-key-here

# OpenAI model to use
# Options: gpt-4-turbo, gpt-4, gpt-3.5-turbo, etc.
# Default: gpt-4-turbo-mini
OPENAI_MODEL=gpt-4-turbo-mini

# ------------------------------------------------------------------------------
# 🟢 DEV-ONLY: Assistant Debug Mode
# ------------------------------------------------------------------------------
# Enable verbose logging for assistant operations
# PRODUCTION: Should be False
# DEVELOPMENT: Can be True for debugging
ASSISTANT_DEBUG=False

# ==============================================================================
# LOGGING CONFIGURATION (Production)
# ==============================================================================

# ------------------------------------------------------------------------------
# 🟡 OPTIONAL: Log File Paths
# ------------------------------------------------------------------------------
# PRODUCTION: Specify log file locations
# DEVELOPMENT: Logs to console only

# Main application log file
LOG_FILE=/var/log/nef-cadencia/django.log

# Error-only log file
ERROR_LOG_FILE=/var/log/nef-cadencia/error.log

# Django log level
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
# PRODUCTION: INFO or WARNING
# DEVELOPMENT: DEBUG
DJANGO_LOG_LEVEL=INFO

# ==============================================================================
# ADMIN CONFIGURATION (Production)
# ==============================================================================

# ------------------------------------------------------------------------------
# 🟡 OPTIONAL: Admin Email Notifications
# ------------------------------------------------------------------------------
# PRODUCTION: Emails to receive error notifications (comma-separated)
# Format: Name:email@example.com,Another Name:another@example.com
# 
# Example:
#   ADMINS=John Doe:john@example.com,Jane Smith:jane@example.com
ADMINS=

# ==============================================================================
# SESSION CONFIGURATION (Production)
# ==============================================================================

# ------------------------------------------------------------------------------
# 🟡 OPTIONAL: Session Cookie Age
# ------------------------------------------------------------------------------
# Session timeout in seconds
# PRODUCTION: 3600 (1 hour) recommended for security
# DEVELOPMENT: Can be longer for convenience
# 
# Common values:
#   3600 = 1 hour
#   7200 = 2 hours
#   28800 = 8 hours
#   86400 = 24 hours
SESSION_COOKIE_AGE=3600

# ==============================================================================
# DEVELOPMENT TOOLS (Development Only)
# ==============================================================================

# ------------------------------------------------------------------------------
# 🟢 DEV-ONLY: SQL Query Logging
# ------------------------------------------------------------------------------
# Show SQL queries in console output
# PRODUCTION: Ignored (always False)
# DEVELOPMENT: Set to True to see all database queries
SHOW_SQL=False

# ==============================================================================
# FUTURE INTEGRATIONS (Placeholder)
# ==============================================================================
# Add integration credentials here as needed

# Example: Slack Integration
# SLACK_BOT_TOKEN=
# SLACK_SIGNING_SECRET=

# Example: Twilio Integration
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=

# Example: AWS Services
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=

# Example: Sentry Error Tracking
# SENTRY_DSN=

# Example: Google OAuth
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ==============================================================================
# END OF CONFIGURATION
# ==============================================================================
